{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Account": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "enum": [
                "apiKey"
              ],
              "title": "ApiKeyAccountType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "ApiKeyAccount",
          "type": "object"
        },
        {
          "properties": {
            "email": {
              "type": "string"
            },
            "planType": {
              "$ref": "#/definitions/PlanType"
            },
            "type": {
              "enum": [
                "chatgpt"
              ],
              "title": "ChatgptAccountType",
              "type": "string"
            }
          },
          "required": [
            "email",
            "planType",
            "type"
          ],
          "title": "ChatgptAccount",
          "type": "object"
        }
      ]
    },
    "AccountPrimingProfileOutcome": {
      "enum": [
        "primed",
        "already_active",
        "unsupported_auth",
        "failed"
      ],
      "type": "string"
    },
    "AccountPrimingProfileResult": {
      "properties": {
        "account": {
          "anyOf": [
            {
              "$ref": "#/definitions/Account"
            },
            {
              "type": "null"
            }
          ]
        },
        "afterRateLimits": {
          "anyOf": [
            {
              "$ref": "#/definitions/RateLimitSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "beforeRateLimits": {
          "anyOf": [
            {
              "$ref": "#/definitions/RateLimitSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "outcome": {
          "$ref": "#/definitions/AccountPrimingProfileOutcome"
        },
        "profileName": {
          "type": "string"
        }
      },
      "required": [
        "outcome",
        "profileName"
      ],
      "type": "object"
    },
    "AccountPrimingRunSummary": {
      "properties": {
        "alreadyActiveCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "cancelled": {
          "type": "boolean"
        },
        "completedAt": {
          "format": "int64",
          "type": "integer"
        },
        "failedCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "primedCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "results": {
          "items": {
            "$ref": "#/definitions/AccountPrimingProfileResult"
          },
          "type": "array"
        },
        "startedAt": {
          "format": "int64",
          "type": "integer"
        },
        "unsupportedCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "alreadyActiveCount",
        "cancelled",
        "completedAt",
        "failedCount",
        "primedCount",
        "results",
        "startedAt",
        "unsupportedCount"
      ],
      "type": "object"
    },
    "AccountPrimingStatus": {
      "properties": {
        "currentProfileName": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentRunStartedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "intervalSeconds": {
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "lastRun": {
          "anyOf": [
            {
              "$ref": "#/definitions/AccountPrimingRunSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "running": {
          "type": "boolean"
        },
        "startedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "running"
      ],
      "type": "object"
    },
    "CreditsSnapshot": {
      "properties": {
        "balance": {
          "type": [
            "string",
            "null"
          ]
        },
        "hasCredits": {
          "type": "boolean"
        },
        "unlimited": {
          "type": "boolean"
        }
      },
      "required": [
        "hasCredits",
        "unlimited"
      ],
      "type": "object"
    },
    "PlanType": {
      "enum": [
        "free",
        "go",
        "plus",
        "pro",
        "prolite",
        "team",
        "self_serve_business_usage_based",
        "business",
        "enterprise_cbp_usage_based",
        "enterprise",
        "edu",
        "unknown"
      ],
      "type": "string"
    },
    "RateLimitReachedType": {
      "enum": [
        "rate_limit_reached",
        "workspace_owner_credits_depleted",
        "workspace_member_credits_depleted",
        "workspace_owner_usage_limit_reached",
        "workspace_member_usage_limit_reached"
      ],
      "type": "string"
    },
    "RateLimitSnapshot": {
      "properties": {
        "credits": {
          "anyOf": [
            {
              "$ref": "#/definitions/CreditsSnapshot"
            },
            {
              "type": "null"
            }
          ]
        },
        "limitId": {
          "type": [
            "string",
            "null"
          ]
        },
        "limitName": {
          "type": [
            "string",
            "null"
          ]
        },
        "planType": {
          "anyOf": [
            {
              "$ref": "#/definitions/PlanType"
            },
            {
              "type": "null"
            }
          ]
        },
        "primary": {
          "anyOf": [
            {
              "$ref": "#/definitions/RateLimitWindow"
            },
            {
              "type": "null"
            }
          ]
        },
        "rateLimitReachedType": {
          "anyOf": [
            {
              "$ref": "#/definitions/RateLimitReachedType"
            },
            {
              "type": "null"
            }
          ]
        },
        "secondary": {
          "anyOf": [
            {
              "$ref": "#/definitions/RateLimitWindow"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "RateLimitWindow": {
      "properties": {
        "resetsAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "usedPercent": {
          "format": "int32",
          "type": "integer"
        },
        "windowDurationMins": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "usedPercent"
      ],
      "type": "object"
    }
  },
  "properties": {
    "status": {
      "$ref": "#/definitions/AccountPrimingStatus"
    }
  },
  "required": [
    "status"
  ],
  "title": "AccountPrimingReadResponse",
  "type": "object"
}